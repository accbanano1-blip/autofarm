local function createBtn(text, yPos, color, func)
    local b = Instance.new("TextButton", MainFrame)
    b.Text = text
    -- Kích thước nút lớn hơn: Rộng 90%, Cao 45
    b.Size = UDim2.new(0.9, 0, 0, 45)
    b.Position = UDim2.new(0.05, 0, 0, yPos)
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.new(1,1,1)
    b.TextSize = 18 -- Chữ trong nút to hơn
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8) -- Bo góc nút
    b.MouseButton1Click:Connect(func)
    return b
end

