-- Hàm kiểm tra xem quái có nằm trong danh sách đen không
function isBlacklisted(mobName)
    for _, name in pairs(blacklistedMobs) do
        if mobName:lower():find(name:lower()) then
            return true
        end
    end
    return false
end

-- Hàm tìm quái gần nhất (loại trừ Blacklist)
function findTarget()
    local target = nil
    local dist = math.huge
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= p.Character then
            -- KIỂM TRA TÊN QUÁI TRƯỚC KHI CHỌN
            if not isBlacklisted(v.Name) then
                local root = v:FindFirstChild("HumanoidRootPart")
                if root then
                    local d = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if d < dist then
                        dist = d
                        target = v
                    end
                end
            end
        end
    end
    return target
end

-- Vòng lặp điều khiển
task.spawn(function()
    while true do
        task.wait(0.5)
        if Running then
            local mob = findTarget()
            if mob and mob:FindFirstChild("HumanoidRootPart") then
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                end
                repeat
                    task.wait(0.2)
                until not Running or not (mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0)
            end
        end
    end
end)

Button.MouseButton1Click:Connect(function()
    Running = not Running
    Button.Text = Running and "TP MOB: ON" or "TP MOB: OFF"
    Button.BackgroundColor3 = Running and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(150, 0, 0)
end)
