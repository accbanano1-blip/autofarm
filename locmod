if pg:FindFirstChild("OneTimeTPGui") then
    pg.OneTimeTPGui:Destroy()
end

local ScreenGui = Instance.new("ScreenGui", pg)
local Button = Instance.new("TextButton", ScreenGui)
local UICorner = Instance.new("UICorner", Button)

ScreenGui.Name = "OneTimeTPGui"
ScreenGui.ResetOnSpawn = false

-- THIẾT LẬP NÚT BẤM
Button.Size = UDim2.new(0, 160, 0, 50)
Button.Position = UDim2.new(0.5, -80, 0.15, 0)
Button.TextColor3 = Color3.fromRGB(255, 255, 255)
Button.Font = Enum.Font.SourceSansBold
Button.TextSize = 18
Button.Draggable = true 
Button.Active = true
UICorner.CornerRadius = UDim.new(0, 12)

-- BIẾN ĐIỀU KHIỂN: MẶC ĐỊNH LÀ TRUE ĐỂ CHẠY LUÔN
local Running = true
Button.Text = "Auto TP: ON"
Button.BackgroundColor3 = Color3.fromRGB(0, 120, 255) -- Màu xanh dương (Đang chạy)

-- Hàm tìm quái gần nhất
function findTarget()
    local target = nil
    local dist = math.huge
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= p.Character then
            local root = v:FindFirstChild("HumanoidRootPart")
            if root then
                local d = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
                if d < dist then
                    dist = d
                    target = v
                end
            end
        end
    end
    return target
end

-- Vòng lặp điều khiển
task.spawn(function()
    while true do
        task.wait(0.5)
        if Running then
            local mob = findTarget()
            if mob and mob:FindFirstChild("HumanoidRootPart") then
                -- THỰC HIỆN TP 1 LẦN
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                end
                
                -- ĐỢI CHO ĐẾN KHI QUÁI CHẾT HOẶC TẮT SCRIPT
                repeat
                    task.wait(0.2)
                until not Running or not mob:FindFirstChild("Humanoid") or mob.Humanoid.Health <= 0
            end
        end
    end
end)

-- Sự kiện Click để TẮT/BẬT
Button.MouseButton1Click:Connect(function()
    Running = not Running
    if Running then
        Button.Text = "Auto TP: ON"
        Button.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    else
        Button.Text = "Auto TP: OFF"
        Button.BackgroundColor3 = Color3.fromRGB(150, 0, 0) -- Màu đỏ (Đã tắt)
    end
end)
