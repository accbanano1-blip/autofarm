local GotoFrame = Instance.new("Frame", MainFrame)
GotoFrame.BackgroundTransparency = 1
GotoFrame.LayoutOrder = 5
local GotoInput = Instance.new("TextBox", GotoFrame)
GotoInput.PlaceholderText = "Tên..."
GotoInput.Size = UDim2.new(1, 0, 1, 0)
