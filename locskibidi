GotoInput.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", GotoInput)

createGridBtn("GOTO", Color3.fromRGB(100, 0, 200), 6).MouseButton1Click:Connect(function()
    local t = GotoInput.Text:lower()
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and (v.Name:lower():find(t) or v.DisplayName:lower():find(t)) then
            player.Character.HumanoidRootPart.CFrame = v.Character.HumanoidRootPart.CFrame
            break
        end
    end
end)

local NoclipBtn = createGridBtn("Noclip: OFF", Color3.fromRGB(70, 70, 70), 7)
NoclipBtn.MouseButton1Click:Connect(function()
    noclipOn = not noclipOn
    NoclipBtn.Text = noclipOn and "Noclip: ON" or "Noclip: OFF"
    NoclipBtn.BackgroundColor3 = noclipOn and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(70, 70, 70)
end)

local FloatBtn = createGridBtn("Float: OFF", Color3.fromRGB(70, 70, 70), 8)
FloatBtn.MouseButton1Click:Connect(function()
    floatOn = not floatOn
    FloatBtn.Text = floatOn and "Float: ON" or "Float: OFF"
    FloatBtn.BackgroundColor3 = floatOn and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(70, 70, 70)
    FloatControlFrame.Visible = floatOn 
    if floatOn and player.Character:FindFirstChild("HumanoidRootPart") then
        floatHeight = player.Character.HumanoidRootPart.Position.Y - 3.5
    elseif plate then
        plate:Destroy() plate = nil
    end
end)

UpBtn.MouseButton1Click:Connect(function() if floatOn then floatHeight = floatHeight + 2 end end)
DownBtn.MouseButton1Click:Connect(function() if floatOn then floatHeight = floatHeight - 2 end end)

local SLBtn = createGridBtn("Shiftlock: OFF", Color3.fromRGB(70, 70, 70), 9)
SLBtn.MouseButton1Click:Connect(function()
    slOn = not slOn
    SLBtn.Text = slOn and "Shiftlock: ON" or "Shiftlock: OFF"
    SLBtn.BackgroundColor3 = slOn and Color3.fromRGB(100, 0, 150) or Color3.fromRGB(70, 70, 70)
end)

createGridBtn("TP TOOL", Color3.fromRGB(70, 70, 70), 10).MouseButton1Click:Connect(function()
    local tool = Instance.new("Tool", player.Backpack)
    tool.Name = "TP Tool"
    tool.RequiresHandle = false
    tool.Activated:Connect(function() player.Character.HumanoidRootPart.CFrame = CFrame.new(player:GetMouse().Hit.p) + Vector3.new(0, 3, 0) end)
end)

-- --- CHỨC NĂNG NIGHT VISION MỚI ---
local NVBtn = createGridBtn("NightVision: OFF", Color3.fromRGB(70, 70, 70), 11)
NVBtn.MouseButton1Click:Connect(function()
    nvOn = not nvOn
    NVBtn.Text = nvOn and "NightVision: ON" or "NightVision: OFF"
    NVBtn.BackgroundColor3 = nvOn and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(70, 70, 70)
    
    if nvOn then
        -- Khi bật: Đưa mọi thứ về trạng thái sáng rực
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    else
        -- Khi tắt: Khôi phục lại mặc định
        Lighting.Brightness = originalBrightness
        Lighting.ClockTime = originalClockTime
        Lighting.FogEnd = originalFogEnd
        Lighting.GlobalShadows = true
        Lighting.OutdoorAmbient = Color3.fromRGB(127, 127, 127)
    end
end)

-- --- VÒNG LẶP XỬ LÝ ---
RunService.Stepped:Connect(function()
    if not player.Character then return end
    if noclipOn then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide == true then v.CanCollide = false end
        end
    end
end)

RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local hum = char:FindFirstChild("Humanoid")

    if hum then hum.WalkSpeed = speedOn and (tonumber(SpeedInput.Text) or 16) or 16 end

    if floatOn then
        if not plate or plate.Parent ~= workspace then
            plate = Instance.new("Part", workspace)
            plate.Size = Vector3.new(15, 1, 15)
            plate.Anchored = true
            plate.Transparency = 0.7
            plate.BrickColor = BrickColor.new("Cyan")
        end
        plate.CFrame = CFrame.new(hrp.Position.X, floatHeight, hrp.Position.Z)
    end

    if slOn and hum then
        hum.AutoRotate = false
        hum.CameraOffset = Vector3.new(1.7, 0, 0)
        hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(workspace.CurrentCamera.CFrame.LookVector.X, 0, workspace.CurrentCamera.CFrame.LookVector.Z))
    elseif hum then
        hum.AutoRotate = true
        hum.CameraOffset = Vector3.new(0, 0, 0)
    end
    
    -- Giữ Night Vision luôn hoạt động nếu game có script tự đổi giờ
    if nvOn then
        Lighting.ClockTime = 14
        Lighting.Brightness = 2
    end
end)
