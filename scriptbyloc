local UpB = create("Up", "▲", UDim2.new(0.85, 0, 0.1, 0), UDim2.new(0, 22, 0, 45), Color3.fromRGB(100, 100, 100))
local DownB = create("Down", "▼", UDim2.new(0.85, 0, 0.55, 0), UDim2.new(0, 22, 0, 45), Color3.fromRGB(100, 100, 100))

