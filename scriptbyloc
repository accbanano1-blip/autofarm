-- HÀM TẠO NÚT NHANH
local function create(name, text, pos, size, color)
    local b = Instance.new("TextButton")
    b.Name = name
    b.Text = text
    b.Position = pos
    b.Size = size
    b.BackgroundColor3 = color
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.Font = Enum.Font.SourceSansBold
    b.TextSize = 16
    b.Parent = Main
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 6)
    c.Parent = b
    return b
end

local SetB = create("Set", "SET", UDim2.new(0.05, 0, 0.1, 0), UDim2.new(0, 65, 0, 45), Color3.fromRGB(200, 50, 50))
