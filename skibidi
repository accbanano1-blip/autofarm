local function styleBtn(btn, txt, clr)
    btn.Size = UDim2.new(1, 0, 0, 45)
    btn.Text = txt
    btn.BackgroundColor3 = clr
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 16
    return btn
end

